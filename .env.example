# --- Twilio ---
# From the Twilio Console dashboard (https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# A Twilio phone number that is VOICE + SMS capable (E.164, e.g. +18885551234)
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Optional: a second VERIFIED number to receive live transfers (escalations).
# Leave blank to stub live transfer (logs escalation + sets disposition orange).
COORDINATOR_NUMBER=

# --- "Talk on browser" (Twilio Voice JS SDK) ---
# 1) Create an API Key: Console > Account > API keys & tokens > Create API key (Standard).
# 2) Create a TwiML App: Console > Voice > TwiML Apps > Create.
#    Set its Voice Request URL to:  https://<PUBLIC_URL>/voice/browser   (HTTP POST)
# Leave these blank to disable browser voice (the phone "Call" path still works).
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret
TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OpenAI (GPT-4.1) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1

# --- Public URL (ngrok) ---
# The ngrok host WITHOUT protocol, e.g. abcd-1234.ngrok-free.app
# ConversationRelay will connect to wss://<PUBLIC_URL>/ws
PUBLIC_URL=your-id.ngrok-free.app
